generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  technician
  client
}

enum TicketStatus {
  open
  in_progress
  closed
}

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String

  role UserRole @default(client)

  avatarUrl String?

  clientTickets Ticket[] @relation("ClientTickets")

  technicianTickets Ticket[] @relation("TechnicianTickets")

  availabilities TechnicianAvailability[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Service {
  id String @id @default(uuid())

  name String

  amount Float

  active Boolean @default(true)

  tickets Ticket[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("services")
}

model Ticket {
  id String @id @default(uuid())

  title String

  description String

  serviceId String @map("service_id")

  service Service @relation(fields: [serviceId], references: [id])

  clientId String @map("client_id")

  client User @relation("ClientTickets",fields: [clientId],references: [id],onDelete: Cascade)

  technicianId String @map("technician_id")

  technician User @relation("TechnicianTickets",fields: [technicianId], references: [id])

  status TicketStatus @default(open)

  additionalServices AdditionalService[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("tickets")
}

model AdditionalService {
  id String @id @default(uuid())

  ticketId String @map("ticket_id")

  ticket Ticket @relation(fields: [ticketId],references: [id],onDelete: Cascade)

  description String

  amount Float

  createdAt DateTime @default(now()) @map("created_at")

  @@map("additional_services")
}

model TechnicianAvailability {
  id String @id @default(uuid())

  technicianId String @map("technician_id")

  technician User @relation(fields: [technicianId],references: [id],onDelete: Cascade)

  hour String

  @@map("technician_availability")
}