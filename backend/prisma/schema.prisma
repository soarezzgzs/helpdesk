generator client {
  provider = "prisma-client"
  output   = "../src/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  technician
  client
}

enum TicketStatus {
  open
  in_progress
  closed
}

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String

  role UserRole @default(client)

  avatarUrl String?

  clientTickets Ticket[] @relation("ClientTickets")

  technicianTickets Ticket[] @relation("TechnicianTickets")

  availabilities TechnicianAvailability[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Service {
  id          String @id @default(uuid())
  name        String
  description String
  amount      Float

  active Boolean @default(true)

  ticketServices TicketService[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("services")
}

model Ticket {
  id String @id @default(uuid())

  clientId String @map("client_id")
  client   User   @relation("ClientTickets", fields: [clientId], references: [id], onDelete: Cascade)

  technicianId String @map("technician_id")
  technician   User   @relation("TechnicianTickets", fields: [technicianId], references: [id])

  status TicketStatus @default(open)

  ticketServices TicketService[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("tickets")
}

model TicketService {
  ticketId String @map("ticket_id")
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  serviceId String  @map("service_id")
  service   Service @relation(fields: [serviceId], references: [id])

  @@id([ticketId, serviceId])
  @@map("ticket_services")
}

model TechnicianAvailability {
  id String @id @default(uuid())

  technicianId String @map("technician_id")
  technician   User   @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  hour String

  @@map("technician_availability")
}
